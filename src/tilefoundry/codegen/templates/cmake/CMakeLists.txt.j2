{# Per-target split-pipeline build: device .cu (nvcc) + host .cpp (host cxx) #}
{# linked into one host-callable shared library. Mirrors the prior hand-written #}
{# nvcc/g++ commands; kept in sync with codegen.linker.link_modules. #}
cmake_minimum_required(VERSION 3.18)
project({{ name }} LANGUAGES CXX CUDA)

set(CMAKE_CXX_STANDARD 17)
set(CMAKE_CXX_STANDARD_REQUIRED ON)
set(CMAKE_CXX_EXTENSIONS OFF)
set(CMAKE_CUDA_STANDARD 17)
set(CMAKE_CUDA_STANDARD_REQUIRED ON)
set(CMAKE_CUDA_EXTENSIONS OFF)
set(CMAKE_POSITION_INDEPENDENT_CODE ON)
set(CMAKE_LIBRARY_OUTPUT_DIRECTORY ${CMAKE_BINARY_DIR})

add_library({{ name }} SHARED device.cu host.cpp)
set_target_properties({{ name }} PROPERTIES
  PREFIX "lib"
  OUTPUT_NAME "{{ name }}"
  CUDA_ARCHITECTURES "{{ cuda_arch }}")

# Per-source target macro: device gets CUDA, host gets CPU. Never both in one TU.
set_source_files_properties(device.cu PROPERTIES COMPILE_DEFINITIONS TILEFOUNDRY_TARGET_CUDA)
set_source_files_properties(host.cpp PROPERTIES COMPILE_DEFINITIONS TILEFOUNDRY_TARGET_CPU)

# Device nvcc flags (matches the prior hand-written nvcc command).
set_source_files_properties(device.cu PROPERTIES COMPILE_OPTIONS "{{ device_options }}")

target_include_directories({{ name }} PRIVATE
{%- for inc in includes %}
  "{{ inc }}"
{%- endfor %}
)

# Static libstdc++ at link. CMake device-links the CUDA objects then links the
# shared library with the host compiler (+ CUDA runtime libs), so the prior
# `nvcc -shared -Xcompiler -static-libstdc++` (which forwarded the flag to the
# host compiler) becomes the host-compiler flag directly.
target_link_options({{ name }} PRIVATE -static-libstdc++)
